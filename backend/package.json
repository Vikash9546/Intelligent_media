{
  "name": "intelligent-media-processing-pipeline",
  "version": "1.0.0",
  "description": "Intelligent Media Processing Pipeline — async image analysis with BullMQ, Sharp, Tesseract, and PostgreSQL",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "migrate": "ts-node src/db/migrate.ts",
    "migrate:prod": "node dist/db/migrate.js",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bull-board/api": "^5.14.3",
    "@bull-board/express": "^5.14.3",
    "bullmq": "^5.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exif-reader": "^2.0.1",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "file-type": "^19.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "sharp": "^0.33.4",
    "tesseract.js": "^5.1.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
