# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/media_pipeline
DB_HOST=localhost
DB_PORT=5432
DB_NAME=media_pipeline
DB_USER=postgres
DB_PASSWORD=password
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# BullMQ
QUEUE_CONCURRENCY=3
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=2000

# Logging
LOG_LEVEL=info
